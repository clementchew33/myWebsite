{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "food-order-website",
  "main": "src/index.js",
  "compatibility_date": "2026-04-03",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "secrets": {
    "required": ["DISCORD_WEBHOOK_URL"]
  }
}
